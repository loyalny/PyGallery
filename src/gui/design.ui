  <property name="styleSheet">
   <string notr="true">QWidget {
	font-size: 18px;
    font-family: 'JetBrains Mono';
}

#sidebar QPushButton,
#media_page_header QPushButton,
#locked_folder_page_header QPushButton,
#photo_page_header QPushButton,
#video_page_header QPushButton,
#settings_page_scroll_area_widget QPushButton {
	border: none;
    border-radius: 25px;
    color: #444746;
    padding: 15px;
    text-align: left;
    font-weight: 600;
}

#sidebar QPushButton:hover,
#media_page_header QPushButton:hover,
#locked_folder_page_header QPushButton:hover,
#photo_page_header QPushButton:hover,
#video_page_header QPushButton:hover,
#settings_page_scroll_area_widget QPushButton:hover {
	background-color: #e5e5e5;
}

#sidebar QPushButton:pressed,
#media_page_header QPushButton:pressed,
#locked_folder_page_header QPushButton:pressed,
#photo_page_header QPushButton:pressed,
#video_page_header QPushButton:pressed,
#settings_page_scroll_area_widget QPushButton:pressed {
	background-color: #c2ffc2;
}

#widget_8 QPushButton {
	padding: 10px;
	border-radius: 10px;
}

#widget_8 QPushButton:hover {
	background-color: #e5e5e5;
}

#widget_8 QPushButton:pressed {
	background-color: #c2ffc2;
}

#media_page_header_label, #locked_folder_page_header_label, #photo_page_header_label, #video_page_header_label, #settings_page_header_label {
	font-size: 22px;
}

#settings_page_properties_main_label, #label, #label_4 {
	font-size: 20px;
	font-weight: bold;
}

QScrollBar:vertical {
	background: rgba(0, 0, 0, 0.1);
	width: 10px;
	margin: 0px;
	border-radius: 5px;
}

QScrollBar::handle:vertical {
	background-color: #c2ffc2;
	border-radius: 5px;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical,
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
	background: none;
	height: 0px;
}

QComboBox, QFontComboBox {
	background-color: #f3f3f3;
	padding: 10px;
	border-radius: 15px;
}
            
QComboBox:hover, QFontComboBox:hover {
	background-color: #e5e5e5;
}
            
QComboBox QAbstractItemView {
	background-color: #f3f3f3;
	selection-background-color: #c2ffc2;
	selection-color: #121212;
}
            
QComboBox QAbstractItemView::item {
	color: #444746;
}</string>
